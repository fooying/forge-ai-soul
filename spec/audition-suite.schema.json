{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisoulhub.io/schemas/aisoul-audition-suite.v1.json",
  "title": "AI Soul Audition Suite v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "language", "syntheticOnly", "cases"],
  "properties": {
    "schemaVersion": { "const": "aisoul-audition-suite.v1" },
    "language": { "enum": ["zh-CN", "en"] },
    "syntheticOnly": { "const": true },
    "cases": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "dimensions", "turns", "expected", "forbiddenPatterns"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "dimensions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "profile": { "enum": ["core", "emotional-companion", "tool-capable"] },
          "turns": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role", "content"],
              "properties": {
                "role": { "const": "user" },
                "content": { "type": "string", "minLength": 1 }
              }
            }
          },
          "expected": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "forbiddenPatterns": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
